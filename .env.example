# ASUSRouterControl — non-secret configuration only
# Secrets (username, password) are stored in macOS Keychain

ROUTER_HOST=router.asus.com
ROUTER_PORT=80
USE_SSL=false
POLLING_INTERVAL=60
DATA_DIR=~/.asusroutercontrol
SOUNDSHIELD_EXPORT_PATH=~/.asusroutercontrol/soundshield_network.json

# Optional: comma-separated CDN targets used by multi-source speedtest
# Defaults to cachefly,cloudfront,fastly if unset.
# Cloudflare is always included via dedicated provider.
CDN_TARGETS=cachefly,cloudfront,fastly

# Optional: explicit JSON target definitions (overrides built-ins by name).
CDN_TARGETS_JSON='[{"name":"cachefly","download_urls":["https://cachefly.cachefly.net/1mb.test","https://cachefly.cachefly.net/10mb.test","https://cachefly.cachefly.net/100mb.test"],"server_label":"CacheFly","max_download_bytes":10000000,"pop_header_candidates":[],"cache_header_candidates":[]},{"name":"cloudfront","download_urls":["https://awscli.amazonaws.com/awscli-exe-linux-x86_64.zip"],"latency_url":"https://awscli.amazonaws.com/v2/documentation/api/latest/index.html","server_label":"CloudFront","max_download_bytes":10000000,"pop_header_candidates":["x-amz-cf-pop","x-served-by"],"cache_header_candidates":["x-cache"]},{"name":"fastly","download_urls":["https://raw.githubusercontent.com/torvalds/linux/master/MAINTAINERS","https://raw.githubusercontent.com/torvalds/linux/master/CREDITS","https://raw.githubusercontent.com/torvalds/linux/master/Documentation/admin-guide/README.rst"],"latency_url":"https://raw.githubusercontent.com/torvalds/linux/master/Documentation/admin-guide/README.rst","server_label":"Fastly","max_download_bytes":1000000,"pop_header_candidates":["x-served-by"],"cache_header_candidates":["x-cache"]},{"name":"cloudflare","download_urls":["https://speed.cloudflare.com/__down?bytes=100000","https://speed.cloudflare.com/__down?bytes=1000000","https://speed.cloudflare.com/__down?bytes=10000000"],"latency_url":"https://speed.cloudflare.com/__down?bytes=0","upload_url":"https://speed.cloudflare.com/__up","metadata_url":"https://speed.cloudflare.com/meta","server_label":"Cloudflare","max_download_bytes":10000000,"pop_header_candidates":["cf-ray","x-served-by","x-amz-cf-pop"],"cache_header_candidates":["cf-cache-status","x-cache"]}]'
